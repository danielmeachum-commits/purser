# Copy to .env and customize before `docker compose up`.

# Admin login password (bcrypt-verified at request time).
ADMIN_PASSWORD=change-me

# Secret used to sign session JWTs and service tokens.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=dev-secret-change-me

# Session JWT lifetime in seconds (default: 12 hours).
JWT_TTL_SECONDS=43200

# Set true if you serve over HTTPS (cookie Secure flag).
COOKIE_SECURE=false

# Comma-separated allowlist for browser origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080

# How often the API polls the DB for out-of-band writes (LangGraph / MCP)
# and broadcasts deltas over the WebSocket. Seconds.
POLL_INTERVAL_SECONDS=3.0

# Where the web app reaches the API. Baked into the build.
# Defaults route through nginx in the web container (same-origin), which
# works behind any reverse proxy. Override only if the web app needs to
# talk to an API on a different origin.
VITE_API_BASE=/api
VITE_WS_BASE=

# Where the web app reaches the LangGraph dev server. Baked into the build.
# Defaults to the same-origin nginx proxy path `/langgraph`, which forwards
# to the `langgraph` service in docker-compose. Override only if you split
# the LangGraph server onto a different host.
VITE_LANGGRAPH_BASE=/langgraph

# Where the LangGraph container reaches your local LLM (llama-swap etc.).
# Inside the container, `localhost` is the container itself, not your host.
# The compose file sets `extra_hosts: host.docker.internal:host-gateway`
# so this hostname resolves on both Docker Desktop (macOS/Windows) and
# Podman/Linux. Override only if your LLM lives on a different host.
LOCAL_LLM_BASE_URL=http://host.docker.internal:9292/v1
